# === SolScout AI Configuration ===

# Qwen API (Alibaba Cloud DashScope)
QWEN_API_KEY=sk-your-qwen-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-max

# Solana Wallet (Agent's trading wallet)
# Generate with: python -c "from src.utils.wallet import create_wallet; create_wallet()"
SOLANA_PRIVATE_KEY=
SOLANA_WALLET_ADDRESS=

# X/Twitter API (for Social layer - optional)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Trading Settings
MAX_POSITION_PCT=5
TAKE_PROFIT_1=30
TAKE_PROFIT_2=60
STOP_LOSS=15
MIN_LIQUIDITY_USD=5000
MIN_HOLDERS=50
SCAN_INTERVAL_SECONDS=120
